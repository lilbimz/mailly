# Boomlify Temp Mail API Configuration
# Get your API key from: https://boomlify.com/temp-mail-api
BOOMLIFY_API_KEY=your_api_key_here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# SEO Configuration (Optional - for production)
# Get verification codes from respective webmaster tools
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
